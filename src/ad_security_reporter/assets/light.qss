QWidget { background: #f8fafc; color: #0f172a; }
QTableView { gridline-color: #cbd5e1; selection-background-color: #93c5fd; }
QPushButton { background: #e2e8f0; border: 1px solid #cbd5e1; padding: 6px; border-radius: 6px; }
QLineEdit, QComboBox { background: #ffffff; border: 1px solid #cbd5e1; padding: 4px; }
